    "dev": "concurrently \"npm run frontend\" \"npm run backend\"",
    "build": "vite build --config frontend/vite.config.ts",
    "start": "node backend/dist/index.js"
  },
  "dependencies": {
    "express": "^4.17.1",
    "mongoose": "^5.10.9",
    "zod": "^1.11.6"
  },
  "devDependencies": {
    "typescript": "^4.4.4",
    "ts-node": "^10.4.0",
    "vite": "^2.6.4",
    "tailwindcss": "^2.2.19",
    "concurrently": "^6.2.1",
    "@types/express": "^4.17.13",
    "@types/node": "^16.11.7"
  }
}